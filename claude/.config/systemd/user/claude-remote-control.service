[Unit]
Description=Claude Remote Control
After=network.target

[Service]
Type=exec
WorkingDirectory=%h
ExecStart=/bin/sh -c 'exec %h/.local/bin/claude remote-control --permission-mode bypassPermissions --name "$(hostname)$(pwd | sed s:/:--:g)"'
StandardOutput=journal
StandardError=journal
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
