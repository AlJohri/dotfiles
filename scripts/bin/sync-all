#!/usr/bin/env bash

set -euo pipefail

for dir in */; do
    if [[ -d "${dir}.git" ]]; then
        branch=$(git -C "$dir" branch --show-current)

        # If the current branch tracks a remote branch that no longer exists, switch to default branch
        remote_branch=$(git -C "$dir" config --get "branch.${branch}.merge" 2>/dev/null || true)
        if [[ -n "$remote_branch" ]] && ! git -C "$dir" ls-remote --exit-code --heads origin "$remote_branch" &>/dev/null; then
            default_branch=$(git -C "$dir" remote show origin 2>/dev/null | sed -n 's/.*HEAD branch: //p')
            default_branch=${default_branch:-main}
            echo -e "\033[33m⟳ ${dir%/} (${branch}) remote branch gone, switching to ${default_branch}\033[0m"
            git -C "$dir" checkout "$default_branch"
            branch=$default_branch
        fi

        if [[ "$branch" != "main" ]]; then
            branch_display="\033[33m${branch}\033[0m"
        else
            branch_display="${branch}"
        fi

        if git -C "$dir" pull; then
            echo -e "\033[32m✓ ${dir%/}\033[0m (${branch_display}) \033[32msucceeded\033[0m"
        else
            echo -e "\033[31m✗ ${dir%/}\033[0m (${branch_display}) \033[31mfailed\033[0m"
        fi
    fi
done
