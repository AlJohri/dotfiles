#!/usr/bin/env bash
set -euo pipefail

sync_repo() {
    local dir="$1"
    local repo="$2"

    # Fetch once per repo
    if git -C "$dir" fetch --prune 2>/dev/null; then
        echo -e "\033[34m⟳ ${repo}\033[0m fetched"
    else
        echo -e "\033[31m✗ ${repo}\033[0m fetch failed"
        return
    fi

    # Prune worktree entries with missing directories
    git -C "$dir" worktree prune 2>/dev/null

    # For bare repos, skip the bare root during iteration (it has no working tree).
    # For non-bare repos, the main worktree IS the repo root and should be pulled.
    local is_bare repo_root=""
    is_bare="$(git -C "$dir" rev-parse --is-bare-repository 2>/dev/null || echo false)"
    if [ "$is_bare" = "true" ]; then
        repo_root="$(git -C "$dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
        repo_root="${repo_root%/.git}"
    fi

    # Iterate over all worktrees (skip bare root and detached HEADs)
    local wt_path="" wt_branch="" wt_bare=""
    while IFS= read -r line; do
        case "$line" in
            "worktree "*)
                wt_path="${line#worktree }"
                wt_branch=""
                wt_bare=""
                ;;
            "branch "*)
                local branch_ref="${line#branch }"
                wt_branch="${branch_ref#refs/heads/}"
                ;;
            "bare")
                wt_bare="1"
                ;;
            "")
                if [ -n "$wt_bare" ] || [ -z "$wt_branch" ] || [ -z "$wt_path" ]; then
                    wt_path="" wt_branch="" wt_bare=""
                    continue
                fi

                # Skip the bare repo root (has no working tree)
                if [ -n "$repo_root" ] && [ "$wt_path" = "$repo_root" ]; then
                    wt_path="" wt_branch="" wt_bare=""
                    continue
                fi

                # Remove worktrees whose remote branch has been deleted
                if ! git -C "$dir" show-ref --verify --quiet "refs/remotes/origin/$wt_branch"; then
                    if git -C "$dir" worktree remove "$wt_path" 2>/dev/null; then
                        echo -e "  \033[31m✗ ${wt_branch}\033[0m (removed — branch deleted from remote)"
                    else
                        echo -e "  \033[33m⚠ ${wt_branch}\033[0m (branch deleted from remote but worktree has changes)"
                    fi
                    wt_path="" wt_branch="" wt_bare=""
                    continue
                fi

                # Only fast-forward if the branch tracks a remote
                local upstream
                upstream=$(git -C "$wt_path" config "branch.${wt_branch}.remote" 2>/dev/null || true)
                if [ -z "$upstream" ]; then
                    wt_path="" wt_branch="" wt_bare=""
                    continue
                fi

                if git -C "$wt_path" merge --ff-only 2>/dev/null; then
                    echo -e "  \033[32m✓ ${wt_branch}\033[0m"
                else
                    echo -e "  \033[33m⚠ ${wt_branch}\033[0m (not fast-forwardable or dirty)"
                fi

                wt_path="" wt_branch="" wt_bare=""
                ;;
        esac
    done < <(git -C "$dir" worktree list --porcelain; echo "")
}

# If we're inside a bare git repo, sync just this repo
if git rev-parse --is-bare-repository 2>/dev/null | grep -q true; then
    sync_repo "." "$(basename "$PWD")"
    exit 0
fi

# Otherwise, iterate over subdirectories
for dir in */; do
    repo="${dir%/}"

    # Skip non-git directories
    if [ ! -d "${dir}.git" ] && [ ! -f "${dir}.git" ]; then
        continue
    fi

    sync_repo "$dir" "$repo"
done
