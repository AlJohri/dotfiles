#!/usr/bin/env bash
set -euo pipefail

# Bring down a GitHub branch (from a /tree/<branch> URL) as a worktree in the
# bare-repo + worktrees layout.
#
#   - If the repo is already cloned under $DEV_ROOT (default ~/Development),
#     add the branch as a worktree there via `gwt` — using fork notation when
#     the branch's owner differs from the existing clone's origin owner.
#   - Otherwise, do a fresh bare clone into $DEV_ROOT, then add the worktree.

if [ $# -ne 1 ]; then
  echo "Usage: gh-checkout-branch <tree-url>" >&2
  echo "  e.g. https://github.com/<owner>/<repo>/tree/<branch>" >&2
  exit 1
fi

URL="$1"

if [[ "$URL" =~ ^https://github\.com/([^/]+)/([^/]+)/tree/(.+)$ ]]; then
  OWNER="${BASH_REMATCH[1]}"
  REPO="${BASH_REMATCH[2]}"
  BRANCH="${BASH_REMATCH[3]}"
else
  echo "Not a github tree URL: $URL" >&2
  echo "  expected https://github.com/<owner>/<repo>/tree/<branch>" >&2
  exit 1
fi

# Extract the owner segment from a github remote URL (ssh or https form).
remote_owner() {
  local url="$1"
  if [[ "$url" =~ ^https?://[^/]+/([^/]+)/ ]]; then
    echo "${BASH_REMATCH[1]}"
  elif [[ "$url" =~ ^[^@]+@[^:]+:([^/]+)/ ]]; then
    echo "${BASH_REMATCH[1]}"
  fi
}

DEV_ROOT="${DEV_ROOT:-$HOME/Development}"
LOCAL="$DEV_ROOT/$REPO"

if git -C "$LOCAL" rev-parse --git-dir >/dev/null 2>&1; then
  ORIGIN_OWNER=$(remote_owner "$(git -C "$LOCAL" remote get-url origin 2>/dev/null || true)")
  if [ "$OWNER" = "$ORIGIN_OWNER" ]; then
    WT=$(cd "$LOCAL" && gwt "$BRANCH")
  else
    WT=$(cd "$LOCAL" && gwt "$OWNER:$BRANCH")
  fi
else
  DIR=$(git-clone-bare "$OWNER/$REPO" "$LOCAL")
  WT=$(cd "$DIR" && gwt "$BRANCH")
fi

echo >&2
echo "Worktree for '$BRANCH': $WT" >&2
echo "$WT"
