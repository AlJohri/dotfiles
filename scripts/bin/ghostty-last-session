#!/usr/bin/env python3
"""Show the directories from the last Ghostty session.

Reads ~/.local/state/ghostty-tabs.log and finds the most recent cluster
of EXIT events (within a few seconds of each other, indicating a window
close) and reports the last working directory of each tab/pane.
"""

import sys
from pathlib import Path
from datetime import datetime

LOG = Path.home() / ".local/state" / "ghostty-tabs.log"
CLUSTER_GAP_SECONDS = 5  # exits within this window = same session close


def parse_log():
    if not LOG.exists():
        print("No log file found. Open some Ghostty tabs first.")
        sys.exit(1)

    events = []
    for line in LOG.read_text().splitlines():
        parts = line.split(None, 3)
        if len(parts) < 3:
            continue
        kind, ts, pid = parts[0], int(parts[1]), parts[2]
        directory = parts[3] if len(parts) == 4 else None
        events.append((kind, ts, pid, directory))

    return events


def find_last_session(events):
    # Collect all EXIT events
    exits = [(ts, pid) for kind, ts, pid, _ in events if kind == "EXIT"]
    if not exits:
        print("No EXIT events found yet. Close a Ghostty window first.")
        sys.exit(1)

    # Cluster exits by time (window close = all tabs exit within seconds)
    exits.sort(key=lambda x: x[0], reverse=True)
    cluster_time = exits[0][0]
    cluster_pids = set()
    for ts, pid in exits:
        if cluster_time - ts <= CLUSTER_GAP_SECONDS:
            cluster_pids.add(pid)
        else:
            break

    # For each PID in the cluster, find its last known directory
    pid_dirs = {}
    pid_start_times = {}
    for kind, ts, pid, directory in events:
        if pid not in cluster_pids:
            continue
        if kind == "START":
            pid_dirs[pid] = directory
            pid_start_times[pid] = ts
        elif kind == "CD" and directory:
            pid_dirs[pid] = directory

    return cluster_time, pid_start_times, pid_dirs


def main():
    events = parse_log()
    cluster_time, pid_start_times, pid_dirs = find_last_session(events)

    dt = datetime.fromtimestamp(cluster_time)
    print(f"Last session closed at: {dt:%Y-%m-%d %H:%M:%S}")
    print()

    if not pid_dirs:
        print("  (no directories recorded)")
        return

    # Sort by start time so tab order is roughly preserved
    for pid in sorted(pid_dirs, key=lambda p: pid_start_times.get(p, 0)):
        print(f"  PID {pid}  →  {pid_dirs[pid]}")

    if "--reopen" in sys.argv:
        print()
        dirs = [pid_dirs[p] for p in sorted(pid_dirs, key=lambda p: pid_start_times.get(p, 0))]
        # First tab: just cd
        print(f"To reopen, run:")
        for i, d in enumerate(dirs):
            if i == 0:
                print(f"  cd {d}")
            else:
                print(f"  ghostty -e fish -C 'cd {d}' &")


if __name__ == "__main__":
    main()
