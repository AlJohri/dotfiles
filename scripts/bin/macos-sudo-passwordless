#!/usr/bin/env bash
set -euo pipefail

# macOS analogue of omarchy-sudo-passwordless: grant the current user passwordless
# sudo (NOPASSWD: ALL) for a fixed window, then auto-revoke. Handy for driving the
# `sudo` steps of setup scripts over SSH, where there is no TTY to answer a prompt.
#
# Run it in an INTERACTIVE session (you enter your password once); other
# (non-interactive/SSH) sessions then get passwordless sudo until it expires.
#
#   macos-sudo-passwordless [MINUTES]   # enable for MINUTES (default 15); re-arms if active
#   macos-sudo-passwordless off         # revoke now
#
# Auto-revoke is a detached root `sleep` job (like omarchy's transient systemd timer):
# it survives your shell/SSH session but NOT a reboot. If you reboot before it expires,
# run `macos-sudo-passwordless off` to revoke. Security: while active, ANY process
# running as you can run any command as root without a password.

NOPASSWD_FILE="/etc/sudoers.d/99-nopasswd-${USER}"
# Generation token: a dotted name so sudo ignores it in sudoers.d (sudo skips include
# files containing a '.'). Lets a re-arm supersede an older pending timer cleanly.
TOKEN_FILE="/etc/sudoers.d/.nopasswd-${USER}.token"

arg="${1:-15}"

revoke() {
  sudo rm -f "$NOPASSWD_FILE" "$TOKEN_FILE"
  echo "Passwordless sudo DISABLED for ${USER}."
}

if [[ "$arg" == "off" || "$arg" == "0" ]]; then revoke; exit 0; fi
if [[ ! "$arg" =~ ^[0-9]+$ ]]; then
  echo "Usage: $(basename "$0") [MINUTES|off]" >&2; exit 1
fi
MINUTES="$arg"

echo "⚠️  Granting ${USER} passwordless sudo for ${MINUTES} min (NOPASSWD: ALL)."
echo "    While active, any process running as you can run root commands unprompted."

# Validate the sudoers snippet BEFORE it lands in sudoers.d, so a malformed file can
# never break sudo parsing and lock you out.
tmp="$(mktemp)"
printf '%s ALL=(ALL) NOPASSWD: ALL\n' "$USER" > "$tmp"
if ! sudo visudo -cf "$tmp" >/dev/null; then
  echo "sudoers validation failed; aborting." >&2; rm -f "$tmp"; exit 1
fi
sudo install -m 0440 -o root -g wheel "$tmp" "$NOPASSWD_FILE"
rm -f "$tmp"

# New token + detached root timer. At expiry the job revokes only if its token is still
# current, so re-running to re-arm supersedes an older timer instead of racing it.
token="$$-${RANDOM}-${RANDOM}"
sudo bash <<EOF
umask 077
printf '%s' '$token' > '$TOKEN_FILE'
nohup bash -c 'sleep $((MINUTES * 60)); [ "\$(cat "$TOKEN_FILE" 2>/dev/null)" = "$token" ] && rm -f "$NOPASSWD_FILE" "$TOKEN_FILE"' >/dev/null 2>&1 &
EOF

echo "Enabled. Auto-revokes in ${MINUTES} min, or run: $(basename "$0") off"
echo "(A reboot before expiry leaves it active until you revoke.)"
