#!/usr/bin/env bash
set -euo pipefail

build_repo() {
    local dir="$1"
    local repo="$2"

    echo -e "\033[34m⟳ ${repo}\033[0m"

    git -C "$dir" worktree prune 2>/dev/null

    local is_bare repo_root=""
    is_bare="$(git -C "$dir" rev-parse --is-bare-repository 2>/dev/null || echo false)"
    if [ "$is_bare" = "true" ]; then
        repo_root="$(git -C "$dir" rev-parse --path-format=absolute --git-common-dir 2>/dev/null)"
        repo_root="${repo_root%/.git}"
    fi

    local wt_path="" wt_branch="" wt_bare=""
    while IFS= read -r line; do
        case "$line" in
            "worktree "*)
                wt_path="${line#worktree }"
                wt_branch=""
                wt_bare=""
                ;;
            "branch "*)
                local branch_ref="${line#branch }"
                wt_branch="${branch_ref#refs/heads/}"
                ;;
            "bare")
                wt_bare="1"
                ;;
            "")
                if [ -n "$wt_bare" ] || [ -z "$wt_path" ]; then
                    wt_path="" wt_branch="" wt_bare=""
                    continue
                fi

                if [ -n "$repo_root" ] && [ "$wt_path" = "$repo_root" ]; then
                    wt_path="" wt_branch="" wt_bare=""
                    continue
                fi

                if [ ! -f "$wt_path/Cargo.toml" ]; then
                    wt_path="" wt_branch="" wt_bare=""
                    continue
                fi

                local label="${wt_branch:-$(basename "$wt_path")}"
                if (cd "$wt_path" && cargo build 2>&1 | sed 's/^/    /'); then
                    echo -e "  \033[32m✓ ${label}\033[0m"
                else
                    echo -e "  \033[31m✗ ${label}\033[0m (build failed)"
                fi

                wt_path="" wt_branch="" wt_bare=""
                ;;
        esac
    done < <(git -C "$dir" worktree list --porcelain; echo "")
}

# If we're inside a git repo (bare or not), build just this repo's worktrees
if git rev-parse --git-dir >/dev/null 2>&1; then
    build_repo "." "$(basename "$PWD")"
    exit 0
fi

# Otherwise, iterate over subdirectories
for dir in */; do
    repo="${dir%/}"

    if [ ! -d "${dir}.git" ] && [ ! -f "${dir}.git" ]; then
        continue
    fi

    build_repo "$dir" "$repo"
done
