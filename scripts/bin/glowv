#!/bin/bash
# View a markdown file with glow, with mermaid diagrams rendered inline at
# terminal-pixel size. Companion to mdcatv (use mdcatv when you want mdcat's
# inline-image handling for non-mermaid images; use glowv when you want
# glow's table rendering).
#
# Mermaid handling is identical between the two: a single mmdc batch call
# extracts and renders all ```mermaid blocks in one chromium session, then we
# walk the processed output and emit each PNG via the raw Kitty graphics
# protocol (so it's sized to the terminal pixel width rather than glow's
# column box).

set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: glowv <markdown-file> [...]" >&2
  exit 2
fi

default_cols=${GLOWV_COLUMNS:-110}
term_cols=${COLUMNS:-}
if [[ -z "$term_cols" ]]; then
  term_cols=$( (stty size </dev/tty) 2>/dev/null | awk '{print $2}') || true
fi
term_cols=${term_cols:-$default_cols}
cols=$(( default_cols < term_cols ? default_cols : term_cols ))

tmpdir=$(mktemp -d -t glowv.XXXXXX)
trap 'rm -rf "$tmpdir"' EXIT

# Inline mermaid config — kept here so the script is self-contained. Override
# with MERMAID_CONFIG=/path/to/your.json.
mermaid_config="${MERMAID_CONFIG:-}"
if [[ -z "$mermaid_config" ]]; then
  mermaid_config="$tmpdir/mermaid.json"
  cat >"$mermaid_config" <<'EOF'
{
  "theme": "dark",
  "maxTextSize": 500000,
  "maxEdges": 5000,
  "themeVariables": { "fontSize": "18px" },
  "sequence": {
    "useMaxWidth": false,
    "actorMargin": 80,
    "messageMargin": 40,
    "boxMargin": 12,
    "actorFontSize": 18,
    "messageFontSize": 16,
    "noteFontSize": 16,
    "wrap": true
  },
  "flowchart": {
    "useMaxWidth": false,
    "nodeSpacing": 60,
    "rankSpacing": 60,
    "padding": 16
  }
}
EOF
fi
cfg_arg=(-c "$mermaid_config")

have_mermaid=0
command -v mmdc >/dev/null 2>&1 && command -v _kitty-icat >/dev/null 2>&1 && have_mermaid=1

batch_render_mermaid() {
  local src="$1" dst="$2"
  local artdir
  artdir=$(dirname "$dst")
  mmdc "${cfg_arg[@]}" -i "$src" -o "$dst" -e png -t dark -b transparent \
    -w 1800 --scale 2 -a "$artdir" --quiet >/dev/null 2>&1
}

# Inline glow style: dracula with margin: 0 (no left/right padding) and the
# rest of upstream charmbracelet/glamour's dracula.json untouched. Override
# with GLOWV_STYLE=/path/to/your.json (or a built-in name like 'dracula').
glow_style="${GLOWV_STYLE:-}"
if [[ -z "$glow_style" ]]; then
  glow_style="$tmpdir/glow-style.json"
  cat >"$glow_style" <<'EOF'
{
  "document": { "block_prefix": "\n", "block_suffix": "\n", "color": "#f8f8f2", "margin": 0 },
  "block_quote": { "color": "#f1fa8c", "italic": true, "indent": 2 },
  "paragraph": {},
  "list": { "color": "#f8f8f2", "level_indent": 2 },
  "heading": { "block_suffix": "\n", "color": "#bd93f9", "bold": true },
  "h1": { "prefix": "# " },
  "h2": { "prefix": "## " },
  "h3": { "prefix": "### " },
  "h4": { "prefix": "#### " },
  "h5": { "prefix": "##### " },
  "h6": { "prefix": "###### " },
  "text": {},
  "strikethrough": { "crossed_out": true },
  "emph": { "color": "#f1fa8c", "italic": true },
  "strong": { "color": "#ffb86c", "bold": true },
  "hr": { "color": "#6272A4", "format": "\n--------\n" },
  "item": { "block_prefix": "• " },
  "enumeration": { "block_prefix": ". ", "color": "#8be9fd" },
  "task": { "ticked": "[✓] ", "unticked": "[ ] " },
  "link": { "color": "#8be9fd", "underline": true },
  "link_text": { "color": "#ff79c6" },
  "image": { "color": "#8be9fd", "underline": true },
  "image_text": { "color": "#ff79c6", "format": "Image: {{.text}} →" },
  "code": { "color": "#50fa7b" },
  "code_block": {
    "color": "#ffb86c",
    "margin": 0,
    "chroma": {
      "text": { "color": "#f8f8f2" },
      "error": { "color": "#f8f8f2", "background_color": "#ff5555" },
      "comment": { "color": "#6272A4" },
      "comment_preproc": { "color": "#ff79c6" },
      "keyword": { "color": "#ff79c6" },
      "keyword_reserved": { "color": "#ff79c6" },
      "keyword_namespace": { "color": "#ff79c6" },
      "keyword_type": { "color": "#8be9fd" },
      "operator": { "color": "#ff79c6" },
      "punctuation": { "color": "#f8f8f2" },
      "name": { "color": "#8be9fd" },
      "name_builtin": { "color": "#8be9fd" },
      "name_tag": { "color": "#ff79c6" },
      "name_attribute": { "color": "#50fa7b" },
      "name_class": { "color": "#8be9fd" },
      "name_constant": { "color": "#bd93f9" },
      "name_decorator": { "color": "#50fa7b" },
      "name_exception": {},
      "name_function": { "color": "#50fa7b" },
      "name_other": {},
      "literal": {},
      "literal_number": { "color": "#6EEFC0" },
      "literal_date": {},
      "literal_string": { "color": "#f1fa8c" },
      "literal_string_escape": { "color": "#ff79c6" },
      "generic_deleted": { "color": "#ff5555" },
      "generic_emph": { "color": "#f1fa8c", "italic": true },
      "generic_inserted": { "color": "#50fa7b" },
      "generic_strong": { "color": "#ffb86c", "bold": true },
      "generic_subheading": { "color": "#bd93f9" },
      "background": { "background_color": "#282a36" }
    }
  },
  "table": {},
  "definition_list": {},
  "definition_term": {},
  "definition_description": { "block_prefix": "\n🠶 " },
  "html_block": {},
  "html_span": {}
}
EOF
fi

flush_prose() {
  local buf="$1"
  [[ -s "$buf" ]] || return 0
  glow --style "$glow_style" --width "${GLOWV_WIDTH:-0}" "$buf" </dev/null
  : > "$buf"
}

process_file() {
  local file="$1"
  local processed="$tmpdir/processed-$(basename "$file")"
  local source="$file"
  if (( have_mermaid )) && grep -q '^```mermaid' "$file" 2>/dev/null; then
    if batch_render_mermaid "$file" "$processed"; then
      source="$processed"
    fi
  fi

  local prose="$tmpdir/prose"
  : > "$prose"
  local artdir
  artdir=$(dirname "$processed")
  while IFS= read -r line || [[ -n "$line" ]]; do
    if [[ "$line" =~ ^!\[[^]]*\]\((\./)?(processed-[a-zA-Z0-9._-]+\.png)\)$ ]]; then
      flush_prose "$prose"
      _kitty-icat "$artdir/${BASH_REMATCH[2]}" </dev/null || printf '%s\n' "$line" >> "$prose"
      continue
    fi
    printf '%s\n' "$line" >> "$prose"
  done <"$source"
  flush_prose "$prose"
}

clear
printf '\e[3J'

for f in "$@"; do
  process_file "$f"
done

if command -v hyprctl >/dev/null 2>&1; then
  hyprctl dispatch sendshortcut "CTRL SHIFT, K," >/dev/null
elif [[ "$(uname)" == "Darwin" ]]; then
  osascript -e 'tell application "System Events" to keystroke "k" using {control down, shift down}'
fi
