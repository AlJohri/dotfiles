#!/usr/bin/env bash
days="${1:-3}"
start_date=$(date -d "$days days ago" +%Y-%m-%d)
end_date=$(date +%Y-%m-%d)
tz_offset=$(date +%z | awk '{ s=substr($0,1,1); h=substr($0,2,2)+0; m=substr($0,4,2)+0; v=h*3600+m*60; print (s=="-" ? -v : v) }')
gh api "search/issues?q=is:pr+author:@me+merged:${start_date}..${end_date}&per_page=100&sort=updated&order=desc" \
  --jq '
    def local_date: .pull_request.merged_at | fromdateiso8601 + '"$tz_offset"' | strftime("%Y-%m-%d");
    .items | group_by(local_date) | sort_by(.[0] | local_date) | reverse | .[] | [
      "\n\u001b[1;37m" + (.[0] | local_date) + "\u001b[0m\n",
      (.[] | "  \u001b[34m" + (.repository_url | split("/") | .[-2:] | join("/")) + "\u001b[0m \u001b]8;;" + .html_url + "\u0007\u001b[36m#" + (.number | tostring) + "\u001b]8;;\u0007\u001b[0m " + .title)
    ] | .[]'
