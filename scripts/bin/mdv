#!/bin/bash
# View a markdown file with mdcat, starting from the top of a fresh scrollback.
#
# Workflow:
#   1. Clear the screen + scrollback buffer so the mdcat output starts at the
#      top of Ghostty's scrollback.
#   2. Render the markdown file (inline images work because mdcat writes
#      directly to the terminal — no pager).
#   3. Ask Hyprland to synthesize Ctrl+Shift+K, which matches the Ghostty
#      keybind for `scroll_to_top` (configured in
#      ~/dotfiles/ghostty/.config/ghostty/config).
#
# Requires:
#   - mdcat on PATH (installed via `mise use --global github:swsnr/mdcat@latest`)
#   - hyprctl (Hyprland)
#   - Ghostty with keybind: ctrl+shift+k=scroll_to_top
#
# Caveat: if you run this inside tmux/zellij, the synthesized keypress goes to
# the multiplexer first and scroll_to_top won't fire in Ghostty.

set -euo pipefail

if [[ $# -eq 0 ]]; then
  echo "usage: mdv <markdown-file> [...]" >&2
  exit 2
fi

# Default width — override with MDV_COLUMNS env var. Capped at actual terminal
# width so we don't waste columns on narrow windows.
default_cols=${MDV_COLUMNS:-110}
term_cols=$(tput cols 2>/dev/null || echo "$default_cols")
cols=$(( default_cols < term_cols ? default_cols : term_cols ))

# Clear screen and scrollback so the top of the new output is at the top of scrollback.
clear
printf '\e[3J'

mdcat --columns "$cols" "$@"

# Jump viewport to the top so the user lands on the rendered title.
if command -v hyprctl >/dev/null 2>&1; then
  hyprctl dispatch sendshortcut "CTRL SHIFT, K," >/dev/null
fi
