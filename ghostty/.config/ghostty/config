# Dynamic theme colors
config-file = ?"~/.config/omarchy/current/theme/ghostty.conf"

# Font
font-family = "JetBrainsMono Nerd Font"
font-style = Regular
font-size = 14

# Window
window-theme = ghostty
window-padding-x = 14
window-padding-y = 14
# false so closing a tmux window doesn't prompt — ghostty can't tell tmux is
# safe to close (session persists), and there's no per-process allowlist yet:
# https://github.com/ghostty-org/ghostty/discussions/12719
confirm-close-surface = false
resize-overlay = never
gtk-toolbar-style = flat

# Cursor styling
cursor-style = "block"
cursor-style-blink = false

# Cursor styling + SSH session terminfo
# (all shell integration options must be passed together)
shell-integration-features = no-cursor,ssh-env

# Keyboard bindings
keybind = super+enter=unbind
keybind = shift+insert=paste_from_clipboard
keybind = control+insert=copy_to_clipboard
keybind = super+control+shift+alt+arrow_down=resize_split:down,100
keybind = super+control+shift+alt+arrow_up=resize_split:up,100
keybind = super+control+shift+alt+arrow_left=resize_split:left,100
keybind = super+control+shift+alt+arrow_right=resize_split:right,100

# Scroll to top/bottom of scrollback (Framework 13 has no Home/End key)
keybind = ctrl+shift+k=scroll_to_top
keybind = ctrl+shift+j=scroll_to_bottom

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll

# Skip the per-surface systemd transient scope: a D-Bus round-trip to systemd on
# every new tab/window, measured at ~40ms of shell-spawn latency (A/B, 2026-07-06,
# al-private worklog ghostty-shell-startup-slowness). The scopes carried no
# CPU/IO/memory limits anyway; tradeoff is per-surface OOM-kill granularity.
linux-cgroup = never
