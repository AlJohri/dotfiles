#!/bin/bash
# Toggle an app's visibility, pulling its windows to the current yabai space.
# Usage: toggle-app <AppName>

APP="$1"

if [ -z "$APP" ]; then
    echo "Usage: toggle-app <AppName>" >&2
    exit 1
fi

is_running=$(osascript -e "application \"$APP\" is running")
if [ "$is_running" = "true" ]; then
    is_frontmost=$(osascript -e "tell application \"System Events\" to tell process \"$APP\" to frontmost" 2>/dev/null)
    if [ "$is_frontmost" = "true" ]; then
        osascript -e "tell application \"System Events\" to tell process \"$APP\" to set visible to false"
        exit 0
    fi
fi

SPACE=$(yabai -m query --spaces --space 2>/dev/null | jq .index)
if [ -n "$SPACE" ] && [ "$SPACE" != "null" ]; then
    yabai -m query --windows 2>/dev/null \
        | jq -r --arg app "$APP" --argjson s "$SPACE" '.[] | select(.app==$app) | select(.space != $s) | .id' \
        | while read -r id; do
            yabai -m window "$id" --space "$SPACE" 2>/dev/null
        done
fi

osascript -e "tell application \"$APP\" to activate"
