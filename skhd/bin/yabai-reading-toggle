#!/bin/bash
# Toggle "reading mode" on the focused yabai space: large left/right padding
# centers a single full-screen window so prose / docs render at a comfortable
# reading width instead of stretching across the full monitor.
#
# Bound from skhdrc.

set -euo pipefail

state=/tmp/yabai-reading-mode

if [[ -f $state ]]; then
  yabai -m space --padding abs:10:10:10:10
  rm -f "$state"
else
  yabai -m space --padding abs:10:10:250:250
  touch "$state"
fi
