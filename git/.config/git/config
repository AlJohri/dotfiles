# See https://git-scm.com/docs/git-config

[alias]
	co = checkout
	br = branch
	ci = commit
	st = status
	dt = difftool -d --no-symlinks   # All changed files in one Zed multi-diff (--no-symlinks: editors don't deref the worktree symlinks -d creates)
	bd = "!zed-branch-diff"          # Native Zed `git: branch diff` (branch vs default branch) in the live workspace — LSP/go-to-def work, unlike `dt`
[init]
	defaultBranch = main
[pull]
	rebase = true 			 # Rebase (instead of merge) on pull
[push]
	autoSetupRemote = true   # Automatically set upstream branch on push
[diff]
	algorithm = histogram    # Clearer diffs on moved/edited lines
	colorMoved = plain       # Highlight moved blocks in diffs
	mnemonicPrefix = true    # More intuitive refs in diff output
	tool = zed               # Editor used by `git difftool` (inline `git diff` still uses delta, below)
[difftool]
	prompt = false           # Don't ask "launch zed? [Y/n]" before each diff
[difftool "zed"]
	# Wrapper, not `zed --diff` directly — see git-difftool-zed for why.
	cmd = git-difftool-zed \"$LOCAL\" \"$REMOTE\"
	trustExitCode = true
[commit]
	verbose = true           # Include diff comment in commit message template
	gpgsign = true
[column]
	ui = never               # Never output in columns (default)
[branch]
	sort = -committerdate    # Sort branches by most recent commit first
[tag]
	sort = -version:refname  # Sort version numbers as you would expect
[rerere]
	enabled = true           # Record and reuse conflict resolutions
	autoupdate = true        # Apply stored conflict resolutions automatically
[user]
	name = Al Johri
	email = al.johri@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[rebase]
	autoStash = true
[status]
	showUntrackedFiles = all

[core]
	pager = delta
[interactive]
	diffFilter = delta --color-only
[include]
	path = ~/.config/omarchy/current/theme/delta.gitconfig
[merge]
	conflictStyle = zdiff3
[advice]
	skippedCherryPicks = false
[push]
	autoSetupRemote = true
[credential "https://github.com"]
	helper = !gh auth git-credential
[credential "https://gist.github.com"]
	helper = !gh auth git-credential
[credential]
	helper = cache --timeout 7200
	# Git automatically prepends "git-credential-" to the helper name
	helper = oauth

[gpg]
	format = ssh

[gpg "ssh"]
	allowedSignersFile = ~/.config/git/allowed_signers
