# Link handler for Chrome.
#
# Used only as the default app for http/https/etc. scheme handlers (see
# ~/.config/mimeapps.list). Delegates to the chrome-link wrapper, which reuses
# a Chrome window already on the active workspace (opening a new tab) or opens
# a new window there if none — so links never drag focus to another workspace.

[Desktop Entry]
Name=Google Chrome (link handler)
StartupWMClass=Google-chrome
Exec=chrome-link %U
Icon=google-chrome
Type=Application
NoDisplay=true
StartupNotify=true
MimeType=text/html;x-scheme-handler/http;x-scheme-handler/https;x-scheme-handler/about;x-scheme-handler/unknown;
