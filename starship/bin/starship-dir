#!/bin/sh
# Custom directory display for starship prompt.
# Remaps worktree paths to show the parent repo name instead of the worktree leaf.
# Truncates to 2 path components (matching starship's truncation_length = 2).

# Walk up looking for .git to avoid spawning `git rev-parse` in the common case.
find_repo_root() {
  d="$PWD"
  while [ -n "$d" ] && [ "$d" != "/" ]; do
    if [ -e "$d/.git" ]; then
      printf '%s' "$d"
      return 0
    fi
    d="${d%/*}"
  done
  return 1
}

case "$PWD" in
  */.claude/worktrees/*)
    repo_root="${PWD%%/.claude/worktrees/*}"
    repo_name="${repo_root##*/}"
    parent_dir="${repo_root%/*}"
    parent="${parent_dir##*/}"
    branch_and_rest="${PWD#"$repo_root"/.claude/worktrees/}"
    rest="${branch_and_rest#*/}"
    [ "$rest" = "$branch_and_rest" ] && rest=""
    if [ -n "$rest" ]; then
      printf '…/%s/%s/%s' "$parent" "$repo_name" "$rest"
    else
      printf '…/%s/%s' "$parent" "$repo_name"
    fi
    ;;
  *)
    toplevel=$(find_repo_root) || toplevel=""
    # Bare repos have no .git on disk — fall back to asking git.
    if [ -z "$toplevel" ] && [ "$(git rev-parse --is-bare-repository 2>/dev/null)" = "true" ]; then
      toplevel="$PWD"
    fi
    if [ -n "$toplevel" ]; then
      repo_name="${toplevel##*/}"
      parent_dir="${toplevel%/*}"
      parent="${parent_dir##*/}"
      rel="${PWD#"$toplevel"}"
      rel="${rel#/}"
      if [ -n "$rel" ]; then
        printf '…/%s/%s/%s' "$parent" "$repo_name" "$rel"
      else
        printf '…/%s/%s' "$parent" "$repo_name"
      fi
    else
      path="$PWD"
      case "$path" in
        "$HOME") printf '~'; exit 0 ;;
        "$HOME"/*) path="~${path#"$HOME"}" ;;
      esac
      rest="$path"
      slashes=0
      while [ "$rest" != "${rest#*/}" ]; do
        rest="${rest#*/}"
        slashes=$((slashes + 1))
      done
      if [ "$slashes" -le 2 ]; then
        printf '%s' "$path"
      else
        last="${path##*/}"
        prefix="${path%/*}"
        second_last="${prefix##*/}"
        printf '…/%s/%s' "$second_last" "$last"
      fi
    fi
    ;;
esac
