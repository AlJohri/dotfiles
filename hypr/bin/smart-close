#!/bin/bash
# Close window, but hide Slack/Obsidian to special workspace instead

ACTIVE=$(hyprctl activewindow -j)
CLASS=$(echo "$ACTIVE" | jq -r '.class // empty')

case "${CLASS,,}" in
    *slack*)
        TITLE=$(echo "$ACTIVE" | jq -r '.title // empty')
        if [[ "$TITLE" == *"[Main]"* ]]; then
            hyprctl dispatch movetoworkspacesilent special:slack
        else
            hyprctl dispatch killactive
        fi
        ;;
    *obsidian*)
        hyprctl dispatch movetoworkspacesilent special:obsidian
        ;;
    *)
        hyprctl dispatch killactive
        ;;
esac
